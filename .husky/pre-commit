# Defensive: Claude Code's parallel-worktree flow can leave parent
# .git/config with `core.bare = true` mid-flight, which makes every
# git op in this worktree fail with "fatal: not a work tree". Reset
# before any subsequent git activity. Idempotent no-op when not set.
GIT_COMMON_DIR=$(git rev-parse --git-common-dir 2> /dev/null)
[ -n "$GIT_COMMON_DIR" ] && git config -f "$GIT_COMMON_DIR/config" core.bare false 2> /dev/null

# Fail if nested config directories/files exist (indicates setup ran from wrong directory)
# Uses schema-derived patterns to stay in sync with what safeword creates
bun scripts/check-nested-configs.ts || exit 1

# Version sync: package.json is source of truth, marketplace.json must match
node -e 'var c=require("./packages/cli/package.json").version,m=require("./marketplace.json").plugins[0].version;if(c!=m){console.error("Version mismatch: package.json="+c+" marketplace.json="+m+". Update marketplace.json.");process.exit(1)}'

# Parity contracts: SAFEWORD_SCHEMA.contracts must hold (ticket 144).
# Pairs are NOT enforced here — release test catches pair drift; template
# iteration mid-development is normal. Bypassable with --no-verify.
bun scripts/parity-check.ts --mode=contracts-only || exit 1

# Duplicate-ID guard (ticket 158): two ticket folders with the same `id:`
# frontmatter is silent corruption — fail loud before it lands in main.
bun scripts/check-ticket-ids.ts || exit 1

# Friendly guard: husky prepends node_modules/.bin to PATH, but only resolves
# binaries that actually exist on disk. Fresh git worktrees (and fresh clones)
# don't have node_modules installed yet, so bare `lint-staged` would fail with
# "command not found". Replace that with an actionable message.
# See also: the core.bare reset at the top of this file (ticket #141) — both
# defend against fresh-worktree breakage in Claude Code's parallel flow.
if [ ! -x node_modules/.bin/lint-staged ]; then
  echo "pre-commit: node_modules not installed in this worktree. Run \`bun install\` first." >&2
  exit 1
fi

lint-staged
