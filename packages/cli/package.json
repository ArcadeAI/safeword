{
  "name": "safeword",
  "version": "0.62.0",
  "description": "CLI for setting up and managing safeword development environments",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArcadeAI/safeword.git"
  },
  "homepage": "https://github.com/ArcadeAI/safeword",
  "bugs": "https://github.com/ArcadeAI/safeword/issues",
  "type": "module",
  "bin": {
    "safeword": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./eslint": {
      "import": "./dist/presets/typescript/index.js",
      "types": "./dist/presets/typescript/index.d.ts"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": "^22.22.3 || ^24.16.0 || >=26.3.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node scripts/run-vitest-with-build-lock.mjs",
    "pretest:bdd": "tsup",
    "test:bdd": "cucumber-js",
    "test:done": "node scripts/run-vitest-with-build-lock.mjs tests/hooks/ tests/schema.test.ts",
    "test:integration": "node scripts/run-vitest-with-build-lock.mjs tests/integration/",
    "test:smoke:fast": "node scripts/run-vitest-with-build-lock.mjs tests/hooks/ tests/schema.test.ts tests/integration/quality-gates.test.ts tests/integration/jtbd-gate.test.ts tests/smoke/hook-coverage.test.ts",
    "test:smoke": "node scripts/run-vitest-with-build-lock.mjs tests/hooks/ tests/schema.test.ts tests/integration/quality-gates.test.ts tests/integration/jtbd-gate.test.ts tests/smoke/hook-coverage.test.ts tests/integration/phase0-walkthrough.test.ts tests/integration/golden-path.test.ts",
    "test:smoke:live": "node scripts/run-vitest-with-build-lock.mjs --config vitest.live.config.ts",
    "test:release": "node scripts/run-vitest-with-build-lock.mjs --config vitest.release.config.ts",
    "test:slow": "node scripts/run-vitest-with-build-lock.mjs --config vitest.slow.config.ts",
    "generate:cursor-wrappers": "bun scripts/generate-cursor-wrappers.ts",
    "pretest:watch": "tsup",
    "test:watch": "vitest",
    "test:coverage": "node scripts/run-vitest-with-build-lock.mjs --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests && bun run lint:gherkin && tsc --noEmit",
    "lint:gherkin": "bun src/cli.ts lint-gherkin",
    "clean": "rm -rf dist",
    "prepublishOnly": "node scripts/check-bun-publish.js && bun run test:release && bun run build",
    "lint:eslint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "publint": "publint",
    "lint:sh": "shellcheck **/*.sh"
  },
  "dependencies": {
    "@cucumber/gherkin": "^41.0.0",
    "@cucumber/messages": "^33.0.4",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint-react/eslint-plugin": "5.10.3",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.10",
    "@secretlint/core": "^13.0.2",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@vitest/eslint-plugin": "^1.6.21",
    "commander": "15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-astro": "~2.1.1",
    "eslint-plugin-better-tailwindcss": "4.6.1",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.10",
    "eslint-plugin-playwright": "2.10.4",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "3.1.1",
    "eslint-plugin-security": "4.0.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "4.1.0",
    "eslint-plugin-storybook": "10.4.6",
    "eslint-plugin-turbo": "2.10.3",
    "eslint-plugin-unicorn": "68.0.0",
    "typescript-eslint": "8.62.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@types/estree": "^1.0.9",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "knip": "6.24.0",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "eslint": "^10.4.0"
  },
  "keywords": [
    "cli",
    "safeword",
    "developer-experience",
    "linting",
    "claude-code"
  ],
  "author": "",
  "license": "MIT"
}
